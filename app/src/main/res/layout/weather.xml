<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="64dp"
    android:layout_marginHorizontal="20dp"
    android:layout_marginTop="12dp"
    android:background="@drawable/bg_task_item"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:elevation="0dp">

    <ImageView
        android:id="@+id/ivLocationPin"
        android:layout_width="20dp"
        android:layout_height="20dp"
        app:srcCompat="@drawable/ic_location"
        app:tint="@color/purple"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tvLocationName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#1C1B1F"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/ivLocationPin"
        app:layout_constraintEnd_toStartOf="@id/llWeatherBadge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="Санкт-Петербург, Невский проспект" />

    <LinearLayout
        android:id="@+id/llWeatherBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:textColor="#1C1B1F"
            android:textSize="18sp"
            android:textStyle="bold"
            android:text="+18°" />

        <ImageView
            android:id="@+id/ivWeatherIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            app:tint="#FFA000"
            android:src="@drawable/ic_sunny" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>